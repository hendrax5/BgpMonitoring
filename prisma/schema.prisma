// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model AsnDictionary {
  asn              BigInt   @id
  organizationName String   @map("organization_name")
  lastUpdatedAt    DateTime @updatedAt @map("last_updated_at")
  createdAt        DateTime @default(now()) @map("created_at")
}


model HistoricalEvent {
  eventId          Int      @id @default(autoincrement()) @map("event_id")
  serverName       String   @default("default") @map("server_name")
  eventTimestamp   DateTime @map("event_timestamp")
  deviceName       String   @map("device_name")
  deviceIp         String   @map("device_ip")
  peerIp           String   @map("peer_ip")
  peerDescription  String?  @map("peer_description") // Description/name from router config
  asn              BigInt
  organizationName String   @map("organization_name")
  eventType        String   @map("event_type") // 'UP' or 'DOWN'
  downEventId      BigInt?  @map("down_event_id")
  downtimeDuration Int?     @map("downtime_duration")

  @@index([peerIp])
  @@index([eventTimestamp])
  @@map("historical_event")
}

// BGP log entries fetched from device SSH — stored for history
model BgpLog {
  id          Int      @id @default(autoincrement())
  deviceId    Int      @map("device_id")
  deviceName  String   @map("device_name")
  peerIp      String   @map("peer_ip")
  eventType   String   @map("event_type") // 'UP' | 'DOWN' | 'INFO'
  message     String
  fetchedAt   DateTime @default(now()) @map("fetched_at")

  @@index([deviceId])
  @@index([fetchedAt])
  @@map("bgp_log")
}

model RouterDevice {
  id              Int      @id @default(autoincrement())
  hostname        String   @unique
  ipAddress       String   @unique @map("ip_address")
  vendor          String   @default("mikrotik") // mikrotik | cisco | juniper | huawei | danos | vyos
  
  pollMethod      String   @default("snmp_ssh_mix") @map("poll_method") // snmp_only | ssh_only | snmp_ssh_mix
  
  snmpVersion     String   @default("v2c") @map("snmp_version")
  snmpCommunity   String?  @map("snmp_community")
  snmpPort        Int      @default(161) @map("snmp_port")
  
  sshCredentialId Int?     @map("ssh_credential_id")
  sshCredential   DeviceCredential? @relation(fields: [sshCredentialId], references: [id], onDelete: SetNull)

  createdAt       DateTime @default(now()) @map("created_at")

  @@map("router_device")
}

model DeviceCredential {
  id        Int      @id @default(autoincrement())
  deviceIp  String   @unique @map("device_ip") // Exact IP or CIDR prefix like 10.1.1.
  sshPort   Int      @default(22) @map("ssh_port")
  sshUser   String   @map("ssh_user")
  sshPass   String   @map("ssh_pass")
  vendor    String   @default("cisco") // cisco | juniper | huawei
  notes     String? // Optional label e.g. "Core Routers"
  createdAt DateTime @default(now()) @map("created_at")

  routerDevices RouterDevice[]

  @@map("device_credential")
}

model AppUser {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String // hashed
  createdAt DateTime @default(now()) @map("created_at")

  @@map("app_users")
}

// Key-value store for app configuration (editable from UI)
model AppSettings {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("app_settings")
}
