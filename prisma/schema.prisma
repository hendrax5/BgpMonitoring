// This is your Prisma schema file
// v2.1.0 — Multi-tenancy + RBAC

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Tenant (Organisasi / Pelanggan) ──────────────────────────────────────────
model Tenant {
  id        String   @id @default(uuid())
  name      String   @unique          // Nama organisasi
  slug      String   @unique          // URL-friendly: "pt-mitra-net"
  plan      String   @default("free") // free | pro | enterprise
  createdAt DateTime @default(now())  @map("created_at")

  users            AppUser[]
  devices          RouterDevice[]
  deviceCredentials DeviceCredential[]
  historicalEvents HistoricalEvent[]
  bgpLogs          BgpLog[]
  configBackups    DeviceConfigBackup[]
  settings         AppSettings[]

  @@map("tenants")
}

// ─── User ─────────────────────────────────────────────────────────────────────
model AppUser {
  id        Int      @id @default(autoincrement())
  tenantId  String   @map("tenant_id")
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  username  String
  email     String?
  password  String   // bcrypt hashed
  role      String   @default("viewer") // superadmin | orgadmin | viewer
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([tenantId, username])
  @@index([tenantId])
  @@map("app_users")
}

// ─── ASN Dictionary (global, shared across tenants) ───────────────────────────
model AsnDictionary {
  asn              BigInt   @id
  organizationName String   @map("organization_name")
  lastUpdatedAt    DateTime @updatedAt @map("last_updated_at")
  createdAt        DateTime @default(now()) @map("created_at")

  @@map("asn_dictionary")
}

// ─── BGP State Change Events (per tenant) ─────────────────────────────────────
model HistoricalEvent {
  eventId          Int      @id @default(autoincrement()) @map("event_id")
  tenantId         String   @map("tenant_id")
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  serverName       String   @default("default") @map("server_name")
  eventTimestamp   DateTime @map("event_timestamp")
  deviceName       String   @map("device_name")
  deviceIp         String   @map("device_ip")
  peerIp           String   @map("peer_ip")
  peerDescription  String?  @map("peer_description")
  asn              BigInt
  organizationName String   @map("organization_name")
  eventType        String   @map("event_type")    // 'UP' | 'DOWN'
  downEventId      BigInt?  @map("down_event_id")
  downtimeDuration Int?     @map("downtime_duration")

  @@index([tenantId])
  @@index([peerIp])
  @@index([eventTimestamp])
  @@map("historical_event")
}

// ─── BGP SSH Logs (per tenant) ────────────────────────────────────────────────
model BgpLog {
  id         Int      @id @default(autoincrement())
  tenantId   String   @map("tenant_id")
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  deviceId   Int      @map("device_id")
  deviceName String   @map("device_name")
  peerIp     String   @map("peer_ip")
  eventType  String   @map("event_type") // 'UP' | 'DOWN' | 'INFO'
  message    String
  fetchedAt  DateTime @default(now()) @map("fetched_at")

  @@index([tenantId])
  @@index([deviceId])
  @@index([fetchedAt])
  @@map("bgp_log")
}

// ─── Router Devices (per tenant) ──────────────────────────────────────────────
model RouterDevice {
  id              Int      @id @default(autoincrement())
  tenantId        String   @map("tenant_id")
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  hostname        String
  ipAddress       String   @map("ip_address")
  vendor          String   @default("mikrotik")
  pollMethod      String   @default("snmp_ssh_mix") @map("poll_method")
  snmpVersion     String   @default("v2c") @map("snmp_version")
  snmpCommunity   String?  @map("snmp_community")
  snmpPort        Int      @default(161) @map("snmp_port")
  sshCredentialId Int?     @map("ssh_credential_id")
  sshCredential   DeviceCredential? @relation(fields: [sshCredentialId], references: [id], onDelete: SetNull)
  configBackups   DeviceConfigBackup[]
  isBgpMonitoring Boolean  @default(true) @map("is_bgp_monitoring")
  isConfigBackup  Boolean  @default(true) @map("is_config_backup")
  createdAt       DateTime @default(now()) @map("created_at")

  @@unique([tenantId, hostname])
  @@unique([tenantId, ipAddress])
  @@index([tenantId])
  @@map("router_device")
}

// ─── SSH Credentials (per tenant) ─────────────────────────────────────────────
model DeviceCredential {
  id        Int      @id @default(autoincrement())
  tenantId  String   @map("tenant_id")
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  deviceIp  String   @map("device_ip")
  sshPort   Int      @default(22) @map("ssh_port")
  sshUser   String   @map("ssh_user")
  sshPass   String   @map("ssh_pass")
  vendor    String   @default("cisco")
  notes     String?
  createdAt DateTime @default(now()) @map("created_at")

  routerDevices RouterDevice[]

  @@unique([tenantId, deviceIp])
  @@index([tenantId])
  @@map("device_credential")
}

// ─── App Settings (per tenant) ────────────────────────────────────────────────
model AppSettings {
  id       Int    @id @default(autoincrement())
  tenantId String @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  key      String
  value    String

  @@unique([tenantId, key])
  @@index([tenantId])
  @@map("app_settings")
}

// ─── Global Platform Settings (superadmin only) ───────────────────────────────
model GlobalSettings {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String

  @@map("global_settings")
}

// ─── Configuration Management ──────────────────────────────────────────────────
model DeviceConfigBackup {
  id            Int      @id @default(autoincrement())
  tenantId      String   @map("tenant_id")
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  deviceId      Int      @map("device_id")
  routerDevice  RouterDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  configText    String   @db.Text
  configHash    String   @map("config_hash") // MD5 or SHA256 of configText
  isCompliant   Boolean  @default(true) @map("is_compliant")
  complianceLog String?  @map("compliance_log") @db.Text
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([tenantId])
  @@index([deviceId])
  @@index([configHash])
  @@map("device_config_backup")
}

model CompliancePolicy {
  id           Int      @id @default(autoincrement())
  name         String   @unique
  description  String?
  vendorMatch  String   @map("vendor_match") // 'all', 'cisco', 'mikrotik', dll
  mustMatch    Boolean  @default(true) @map("must_match") // jika true, regex HARUS ada di config. Jika false, TIDAK BOLEH ada.
  regexPattern String   @map("regex_pattern")
  severity     String   @default("warning") // 'warning', 'critical'
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("compliance_policy")
}

// ─── Universal Vendor Profiles (global) ───────────────────────────────────────
model VendorProfile {
  id                 Int      @id @default(autoincrement())
  vendorName         String   @unique  @map("vendor_name") // e.g. "huawei", "mikrotik", "zte"
  connectionMode     String   @default("exec") @map("connection_mode") // 'exec' or 'shell'
  backupCommand      String   @map("backup_command") // e.g. "show running-config"
  disablePagingCmd   String?  @map("disable_paging_cmd") // e.g. "screen-length 0 disable"
  regexRemovePattern String?  @map("regex_remove_pattern") // e.g. "^---- More ----$"
  createdAt          DateTime @default(now()) @map("created_at")

  @@map("vendor_profile")
}
